# Скопируй этот файл в .env и заполни. .env НИКОМУ не показывай и не коммить.
BOT_TOKEN=сюда_токен_от_BotFather
ADMIN_IDS=123456789          # твой Telegram user id (узнать у @userinfobot). Несколько — через запятую
START_BALANCE=10000          # стартовые фантики каждому новому игроку
DAILY_BONUS=500              # базовый ежедневный бонус (растёт со стриком)
CURRENCY=фантики
DB_PATH=predict.db

# --- Mini App (необязательно) ---
WEBAPP_URL=                  # https://<твой-логин>.github.io/<репозиторий>/  (GitHub Pages)
API_PORT=8080                # порт HTTP-API для мини-аппа
